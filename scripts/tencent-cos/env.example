# 复制为 .env.cos（不要提交到 Git），在运行 deploy:cos 前 source：
#   set -a && source .env.cos && set +a && npm run deploy:cos
#
# 存储桶名称须带 APPID，在 COS 控制台「存储桶列表」可复制完整名称。
COS_BUCKET=你的桶名-1250000000
COS_REGION=ap-guangzhou

# 可选：不在本机执行 coscli config 时，可临时传入密钥（勿泄露、勿入库）
# COS_SECRET_ID=AKIDxxxxxxxx
# COS_SECRET_KEY=xxxxxxxx
