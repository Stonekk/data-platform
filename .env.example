# 台本生成模式：template | mock-llm | llm
VITE_SCRIPT_GENERATOR_MODE=llm

# DeepSeek API（仅本地 dev 代理使用，勿提交到 git）
# 在 https://platform.deepseek.com/api_keys 创建，粘贴完整 sk- 开头密钥（约 50 位左右，勿保留中文占位符）
DEEPSEEK_API_KEY=sk-粘贴真实密钥到这里

# 可选：模型与 API 地址（默认 deepseek-chat + https://api.deepseek.com）
# VITE_LLM_MODEL=deepseek-chat
# VITE_LLM_API_BASE_URL=https://api.deepseek.com

# 生产环境若部署了 OpenAI 兼容代理，可配置（静态站点 build 后无 dev 代理时使用）
# VITE_LLM_PROXY_URL=https://your-backend.example.com/llm
